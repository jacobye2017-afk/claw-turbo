{
  "name": "@claw-turbo/openclaw-plugin",
  "version": "0.1.0",
  "description": "Zero-latency regex-based skill routing plugin for OpenClaw. Intercepts known commands before they reach the LLM — 400,000x faster, 100% accurate.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "routing",
    "regex",
    "skill",
    "ollama",
    "local-llm",
    "middleware"
  ],
  "author": "Jacob Ye",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.0"
    }
  }
}
